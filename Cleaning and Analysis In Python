# 1. Negative payment values = refunds or data errors
neg_payments = (payments_clean['total_payment'] < 0).sum()
print(f"\nNegative payments: {neg_payments}")
payments_clean = payments_clean[payments_clean['total_payment'] >= 0]

# 2. Zero freight on physical products = likely data error
#    But zero freight on digital products = valid
#    Flag rather than remove
items['freight_flag'] = np.where(
    items['freight_value'] == 0, 'zero_freight', 'normal'
)

# 3. Delivery days < 0 = delivered before purchase = impossible
impossible = (orders['delivery_days'] < 0).sum()
print(f"Impossible delivery times (<0 days): {impossible}")
orders = orders[
    (orders['delivery_days'] >= 0) | 
    (orders['delivery_days'].isnull())
]

# 4. Extreme delivery times (>365 days) = data error
extreme = (orders['delivery_days'] > 365).sum()
print(f"Extreme delivery times (>365 days): {extreme}")
orders = orders[
    (orders['delivery_days'] <= 365) | 
    (orders['delivery_days'].isnull())
]

# 5. Use IQR to flag payment outliers — keep but flag
Q1 = payments_clean['total_payment'].quantile(0.25)
Q3 = payments_clean['total_payment'].quantile(0.75)
IQR = Q3 - Q1

payments_clean['payment_outlier'] = np.where(
    payments_clean['total_payment'] > Q3 + 1.5 * IQR,
    'high_value_order', 'normal'
)

outlier_count = (payments_clean['payment_outlier']=='high_value_order').sum()
print(f"\nHigh-value outliers flagged (not removed): {outlier_count}")
print("Rationale: These are likely genuine bulk or luxury orders")
